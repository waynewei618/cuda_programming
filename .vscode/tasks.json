{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CUDA Build (Docker)",
      "type": "shell",
      "command": "docker",
      "args": [
        "exec",
        "-w",
        "/workspace/cuda_programming",
        "ubuntu_dev",
        "nvcc",
        "-g",
        "-G",
        "${relativeFile}",
        "-o",
        "${relativeFileDirname}/${fileBasenameNoExtension}.out"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "CUDA Run (Docker)",
      "type": "shell",
      "command": "docker",
      "args": [
        "exec",
        "-w",
        "/workspace/cuda_programming",
        "ubuntu_dev",
        "./${relativeFileDirname}/${fileBasenameNoExtension}.out"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "CUDA Build (Docker)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
